<%- include('../partials/header') %>

<div class="container mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-3xl font-bold text-gray-800">Admin Dashboard</h1>
        <div class="flex gap-4">
            <a href="/admin/products" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">Quản lý sản phẩm</a>
            <a href="/admin/orders" class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition">Quản lý đơn hàng</a>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
            <h3 class="text-gray-500 text-sm font-medium mb-2">Tổng sản phẩm</h3>
            <p class="text-3xl font-bold text-gray-800"><%= stats.productCount %></p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
            <h3 class="text-gray-500 text-sm font-medium mb-2">Tổng đơn hàng</h3>
            <p class="text-3xl font-bold text-gray-800"><%= stats.orderCount %></p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
            <h3 class="text-gray-500 text-sm font-medium mb-2">Khách hàng</h3>
            <p class="text-3xl font-bold text-gray-800"><%= stats.userCount %></p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
            <h3 class="text-gray-500 text-sm font-medium mb-2">Doanh thu (Đã giao)</h3>
            <p class="text-3xl font-bold text-blue-600">
                <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(stats.totalRevenue) %>
            </p>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
