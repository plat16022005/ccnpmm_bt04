<%- include('partials/header') %>

<div class="container mx-auto px-4 py-8">
    <div class="flex items-center space-x-4 mb-8">
        <a href="/orders" class="p-2 rounded-full hover:bg-gray-100 transition-colors">
            <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        </a>
        <h1 class="text-3xl font-bold text-gray-800">Chi tiết đơn hàng #<%= order.id %></h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-8">
            <!-- Items -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-6 border-b border-gray-100 bg-gray-50">
                    <h2 class="font-bold text-gray-800">Sản phẩm đã đặt</h2>
                </div>
                <div class="divide-y divide-gray-100">
                    <% items.forEach(item => { %>
                        <div class="p-6 flex items-center space-x-4">
                            <div class="w-16 h-16 bg-gray-50 rounded-lg flex items-center justify-center p-2 flex-shrink-0">
                                <img src="<%= item.image || 'https://via.placeholder.com/100' %>" alt="<%= item.name %>" class="max-w-full max-h-full object-contain">
                            </div>
                            <div class="flex-1">
                                <h3 class="font-semibold text-gray-800"><%= item.name %></h3>
                                <p class="text-sm text-gray-500">Số lượng: <%= item.quantity %></p>
                            </div>
                            <div class="text-right">
                                <p class="font-bold text-blue-600"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(item.price * item.quantity) %></p>
                                <p class="text-xs text-gray-400"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(item.price) %> / SP</p>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- Shipping Info -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
                <h2 class="text-xl font-bold text-gray-800 mb-6">Thông tin giao nhận</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div>
                        <p class="text-sm text-gray-500 mb-1">Người nhận</p>
                        <p class="font-semibold text-gray-800"><%= order.fullname %></p>
                        <p class="text-gray-600"><%= order.phone %></p>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500 mb-1">Địa chỉ giao hàng</p>
                        <p class="text-gray-800 leading-relaxed"><%= order.shipping_address %></p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Summary -->
        <div class="space-y-8">
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
                <h2 class="text-xl font-bold text-gray-800 mb-6">Tóm tắt thanh toán</h2>
                
                <div class="space-y-4 mb-6">
                    <div class="flex justify-between text-gray-600">
                        <span>Phương thức</span>
                        <span class="font-medium text-gray-800"><%= order.payment_method %></span>
                    </div>
                    <div class="flex justify-between text-gray-600">
                        <span>Trạng thái</span>
                        <% 
                        let statusClass = '';
                        let statusText = '';
                        switch(order.status) {
                            case 'pending': statusClass = 'text-yellow-600'; statusText = 'Đang chờ'; break;
                            case 'confirmed': statusClass = 'text-blue-600'; statusText = 'Đã xác nhận'; break;
                            case 'preparing': statusClass = 'text-indigo-600'; statusText = 'Đang chuẩn bị'; break;
                            case 'shipping': statusClass = 'text-orange-600'; statusText = 'Đang giao'; break;
                            case 'delivered': statusClass = 'text-green-600'; statusText = 'Đã giao'; break;
                            case 'cancelled': statusClass = 'text-red-600'; statusText = 'Đã hủy'; break;
                            case 'cancel_requested': statusClass = 'text-purple-600'; statusText = 'Yêu cầu hủy'; break;
                        }
                        %>
                        <span class="font-bold <%= statusClass %>"><%= statusText %></span>
                    </div>
                    <div class="pt-4 border-t border-gray-100 flex justify-between items-end">
                        <span class="text-lg font-bold text-gray-800">Tổng cộng</span>
                        <span class="text-2xl font-bold text-blue-600"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(order.total_amount) %></span>
                    </div>
                </div>

                <% 
                const now = new Date();
                const createdAt = new Date(order.created_at);
                const diffMinutes = (now - createdAt) / (1000 * 60);
                const canCancel = (order.status === 'pending' || order.status === 'confirmed' || (order.status === 'preparing' && diffMinutes > 30)) && order.status !== 'cancelled' && order.status !== 'delivered' && order.status !== 'shipping' && order.status !== 'cancel_requested';
                %>

                <% if (canCancel || (order.status === 'pending' || order.status === 'confirmed' || order.status === 'preparing')) { %>
                    <button id="cancel-btn" 
                        class="w-full mt-4 py-3 rounded-xl font-bold transition-all
                        <%= (order.status === 'cancelled' || order.status === 'delivered' || order.status === 'shipping' || order.status === 'cancel_requested') ? 'bg-gray-100 text-gray-400 cursor-not-allowed' : 'bg-red-50 text-red-600 hover:bg-red-100 border border-red-200' %>"
                        <%= (order.status === 'cancelled' || order.status === 'delivered' || order.status === 'shipping' || order.status === 'cancel_requested') ? 'disabled' : '' %>
                    >
                        <% if (diffMinutes > 30 && order.status === 'preparing') { %>
                            Yêu cầu hủy đơn hàng
                        <% } else { %>
                            Hủy đơn hàng
                        <% } %>
                    </button>
                    <% if (order.status === 'pending' || order.status === 'confirmed') { %>
                        <p class="text-xs text-center text-gray-400 mt-2">Có thể hủy trực tiếp trong vòng 30 phút sau khi đặt.</p>
                    <% } %>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script>
    const cancelBtn = document.getElementById('cancel-btn');
    if (cancelBtn) {
        cancelBtn.addEventListener('click', async () => {
            if (!confirm('Bạn có chắc chắn muốn hủy đơn hàng này?')) return;
            
            try {
                const res = await fetch('/orders/<%= order.id %>/cancel', { method: 'POST' });
                const result = await res.json();
                
                if (result.success) {
                    alert(result.message);
                    window.location.reload();
                } else {
                    alert(result.message || 'Lỗi khi hủy đơn hàng');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Lỗi khi kết nối đến máy chủ');
            }
        });
    }
</script>

<%- include('partials/footer') %>
