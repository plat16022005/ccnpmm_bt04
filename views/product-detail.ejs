<%- include('partials/header') %>

<div class="container mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6 flex items-center space-x-2">
        <a href="/" class="hover:text-blue-600">Trang chủ</a>
        <span>/</span>
        <a href="/search?category=<%= product.category_id %>" class="hover:text-blue-600"><%= product.category_name %></a>
        <span>/</span>
        <span class="text-gray-800"><%= product.name %></span>
    </nav>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden mb-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-6 md:p-10">
            
            <!-- Product Images (Swiper) -->
            <div class="relative w-full">
                <% if (images.length > 0) { %>
                    <div class="swiper mySwiper w-full h-[400px] md:h-[500px] rounded-2xl border border-gray-100 bg-gray-50">
                        <div class="swiper-wrapper">
                            <% images.forEach(img => { %>
                                <div class="swiper-slide flex items-center justify-center p-4">
                                    <img src="<%= img %>" alt="<%= product.name %>" class="max-w-full max-h-full object-contain">
                                </div>
                            <% }) %>
                        </div>
                        <div class="swiper-button-next"></div>
                        <div class="swiper-button-prev"></div>
                        <div class="swiper-pagination"></div>
                    </div>
                <% } else { %>
                    <div class="w-full h-[400px] md:h-[500px] rounded-2xl border border-gray-100 bg-gray-50 flex items-center justify-center">
                        <span class="text-gray-400">Không có hình ảnh</span>
                    </div>
                <% } %>
            </div>

            <!-- Product Info -->
            <div class="flex flex-col">
                <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= product.name %></h1>
                
                <div class="flex items-center space-x-4 text-sm text-gray-500 mb-6 pb-6 border-b border-gray-100">
                    <div class="flex items-center text-yellow-400">
                        <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                        <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                        <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                        <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                        <svg class="w-4 h-4 fill-current text-gray-300" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                    </div>
                    <span>|</span>
                    <span>Đã bán: <strong class="text-gray-800"><%= product.sold %></strong></span>
                    <span>|</span>
                    <span>Tồn kho: <strong class="text-gray-800"><%= product.stock %></strong></span>
                </div>

                <div class="bg-gray-50 rounded-2xl p-6 mb-6 border border-gray-100">
                    <% if (product.discount_price && product.discount_price < product.price) { %>
                        <div class="flex items-center space-x-4">
                            <span class="text-3xl font-extrabold text-red-600">
                                <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(product.discount_price) %>
                            </span>
                            <span class="text-lg text-gray-400 line-through">
                                <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(product.price) %>
                            </span>
                            <span class="bg-red-100 text-red-600 px-2 py-1 rounded text-sm font-bold">
                                Giảm <%= Math.round((1 - product.discount_price / product.price) * 100) %>%
                            </span>
                        </div>
                    <% } else { %>
                        <div class="text-3xl font-extrabold text-blue-600">
                            <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(product.price) %>
                        </div>
                    <% } %>
                </div>

                <div class="mb-8">
                    <h3 class="font-semibold text-gray-800 mb-2">Mô tả sản phẩm:</h3>
                    <div class="text-gray-600 text-sm leading-relaxed whitespace-pre-wrap"><%= product.description %></div>
                </div>

                <div class="mt-auto">
                    <div class="flex items-center space-x-4 mb-6">
                        <span class="font-medium text-gray-800">Số lượng:</span>
                        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                            <button type="button" class="px-4 py-2 bg-gray-50 hover:bg-gray-100 text-gray-600 font-bold" onclick="decreaseQty()">-</button>
                            <input type="number" id="qty" value="1" min="1" max="<%= product.stock %>" class="w-16 text-center py-2 focus:outline-none border-x border-gray-300 font-medium">
                            <button type="button" class="px-4 py-2 bg-gray-50 hover:bg-gray-100 text-gray-600 font-bold" onclick="increaseQty()">+</button>
                        </div>
                    </div>

                    <div class="flex space-x-4">
                        <button class="flex-1 border border-blue-600 text-blue-600 hover:bg-blue-50 font-bold py-3 px-6 rounded-xl transition-colors flex justify-center items-center">
                            Thêm vào giỏ
                        </button>
                        <button class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-xl shadow-lg shadow-blue-200 transition-colors flex justify-center items-center">
                            Mua ngay
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Similar Products -->
    <% if (similarProducts && similarProducts.length > 0) { %>
        <section class="mt-16">
            <h2 class="text-2xl font-bold text-gray-800 mb-6 border-l-4 border-blue-500 pl-4 uppercase">Sản phẩm tương tự</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                <% similarProducts.forEach(sp => { %>
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl transition-all group flex flex-col h-full relative">
                        <a href="/product/<%= sp.id %>" class="relative aspect-square overflow-hidden bg-gray-50 flex items-center justify-center p-4">
                            <img src="<%= sp.image || 'https://via.placeholder.com/400' %>" alt="<%= sp.name %>" class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-500">
                        </a>
                        <div class="p-5 flex flex-col flex-1">
                            <a href="/product/<%= sp.id %>" class="block mb-2 group-hover:text-blue-600 transition-colors">
                                <h3 class="font-semibold text-gray-800 line-clamp-2"><%= sp.name %></h3>
                            </a>
                            <div class="mt-auto pt-4">
                                <div class="text-blue-600 font-bold text-lg">
                                    <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(sp.discount_price || sp.price) %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </section>
    <% } %>
</div>

<script>
    const maxQty = parseInt('<%= product.stock %>');
    const input = document.getElementById('qty');
    
    function increaseQty() {
        let current = parseInt(input.value);
        if (current < maxQty) {
            input.value = current + 1;
        }
    }
    
    function decreaseQty() {
        let current = parseInt(input.value);
        if (current > 1) {
            input.value = current - 1;
        }
    }
</script>

<%- include('partials/footer') %>
